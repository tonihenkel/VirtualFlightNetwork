{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Plugin Release x64",
            "type": "shell",
            "command": "C:\\Program Files\\Microsoft Visual Studio\\18\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
            "args": [
                "${workspaceFolder}\\Flight Radar Sim Projekt.slnx",
                "/p:Configuration=Release",
                "/p:Platform=x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\Flight Radar Sim Projekt"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Rebuild Plugin Release x64",
            "type": "shell",
            "command": "C:\\Program Files\\Microsoft Visual Studio\\18\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
            "args": [
                "${workspaceFolder}\\Flight Radar Sim Projekt.slnx",
                "/t:Rebuild",
                "/p:Configuration=Release",
                "/p:Platform=x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\Flight Radar Sim Projekt"
            },
            "group": "build",
            "problemMatcher": "$msCompile"
        }
    ]
}
